<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Available Stock | AnyBike</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
:root{
  --red:#d71920;
  --black:#050505;
  --white:#ffffff;
  --light:#f6f6f6;
  --mid:#e7e7e7;
  --text:#111111;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:Arial,Helvetica,sans-serif;
  background:var(--white);
  color:var(--text);
}

header{
  background:#fff;
  border-bottom:4px solid var(--red);
}

.header-inner{
  max-width:1250px;
  margin:auto;
  padding:18px 22px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:24px;
}

.logo{
  width:230px;
  max-width:100%;
  height:auto;
  display:block;
}

nav{
  display:flex;
  gap:22px;
  align-items:center;
  flex-wrap:wrap;
  justify-content:flex-end;
}

nav a{
  color:#111;
  text-decoration:none;
  font-weight:800;
  font-size:15px;
}

nav a:hover,
nav a.active{
  color:var(--red);
}

.hero{
  background:linear-gradient(180deg,#ffffff 0%,#f6f6f6 100%);
  padding:52px 18px 42px;
  text-align:center;
  border-bottom:1px solid var(--mid);
}

.hero h1{
  margin:0 0 10px;
  font-size:46px;
  letter-spacing:.5px;
  color:#111;
}

.hero h1 span{
  color:var(--red);
}

.hero p{
  margin:0;
  font-size:18px;
  color:#444;
}

.wrap{
  max-width:1250px;
  margin:auto;
  padding:26px 18px 40px;
}

.tools{
  background:#fff;
  border:1px solid var(--mid);
  border-radius:16px;
  padding:16px;
  box-shadow:0 8px 24px rgba(0,0,0,.06);
  margin-bottom:22px;
}

.toolbar{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1fr 1fr 1fr 1fr;
  gap:10px;
}

input,
select{
  width:100%;
  padding:13px 12px;
  border:1px solid #d7d7d7;
  border-radius:9px;
  font-size:15px;
  background:#fff;
}

input:focus,
select:focus{
  outline:none;
  border-color:var(--red);
  box-shadow:0 0 0 3px rgba(215,25,32,.12);
}

.count-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  flex-wrap:wrap;
  margin:20px 2px;
}

.count{
  font-weight:900;
  font-size:18px;
}

.small{
  color:#666;
  font-size:14px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  align-items:stretch;
}

.card{
  background:#fff;
  border:1px solid #e3e3e3;
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 4px 14px rgba(0,0,0,.07);
  transition:.2s ease;
  display:flex;
  flex-direction:column;
  height:100%;
}

.card:hover{
  transform:translateY(-3px);
  box-shadow:0 12px 28px rgba(0,0,0,.13);
}

.placeholder{
  height:220px;
  background:#f8f8f8;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  position:relative;
  overflow:hidden;
  border-bottom:1px solid #eee;
}

.placeholder img.bg-logo{
  position:absolute;
  width:78%;
  max-width:290px;
  opacity:.08;
}

.real-image{
  width:100%;
  height:220px;
  object-fit:cover;
  display:block;
  border-bottom:1px solid #eee;
}

.placeholder-text{
  position:relative;
  z-index:2;
  color:#111;
  font-weight:900;
  font-size:20px;
  line-height:1.25;
  text-transform:uppercase;
}

.placeholder-text small{
  display:block;
  margin-top:7px;
  color:var(--red);
  font-size:13px;
  letter-spacing:.7px;
}

.card-body{
  padding:17px;
  display:flex;
  flex-direction:column;
  flex:1;
}

.badge{
  display:inline-block;
  background:#111;
  color:#fff;
  border-radius:999px;
  padding:6px 10px;
  font-size:12px;
  font-weight:900;
  margin-bottom:10px;
  width:max-content;
}

.card h2{
  margin:0 0 8px;
  font-size:23px;
  line-height:1.15;
  min-height:54px;
}

.variant{
  color:#444;
  font-weight:700;
  margin-bottom:8px;
  min-height:24px;
}

.meta{
  color:#555;
  line-height:1.65;
  font-size:15px;
  min-height:28px;
}

.price{
  color:var(--red);
  font-size:27px;
  font-weight:950;
  margin:13px 0 3px;
}

.price-note{
  font-size:12px;
  color:#777;
  margin-bottom:13px;
  min-height:32px;
}

.actions{
  display:grid;
  gap:9px;
  margin-top:auto;
}

button{
  width:100%;
  border:0;
  border-radius:10px;
  padding:13px 12px;
  font-size:15px;
  font-weight:900;
  cursor:pointer;
  transition:.15s ease;
}

button.primary{
  background:var(--red);
  color:#fff;
}

button.primary:hover{
  background:#b9141a;
}

button.dark{
  background:#111;
  color:#fff;
}

button.dark:hover{
  background:#333;
}

button.watch{
  background:#fff;
  color:var(--red);
  border:2px solid var(--red);
}

button.watch:hover,
button.watch.active{
  background:var(--red);
  color:#fff;
}

.load-more{
  max-width:320px;
  margin:30px auto 0;
  display:block;
  background:#111;
  color:#fff;
}

.footer{
  background:#111;
  color:#fff;
  text-align:center;
  padding:34px 16px;
  margin-top:30px;
}

.footer strong{
  display:block;
  font-size:20px;
  letter-spacing:1px;
  margin-bottom:8px;
}

.footer span{
  color:#ddd;
}

@media(max-width:1050px){
  .toolbar{
    grid-template-columns:1fr 1fr 1fr;
  }

  .grid{
    grid-template-columns:1fr 1fr;
  }
}

@media(max-width:720px){
  .header-inner{
    justify-content:center;
    text-align:center;
  }

  nav{
    justify-content:center;
    gap:14px;
  }

  .logo{
    width:210px;
  }

  .hero h1{
    font-size:34px;
  }

  .hero p{
    font-size:16px;
  }

  .toolbar{
    grid-template-columns:1fr;
  }

  .grid{
    grid-template-columns:1fr;
  }

  .card h2{
    min-height:auto;
  }
}
</style>
</head>

<body>

<header>
  <div class="header-inner">
    <a href="index.html">
      <img class="logo" src="anybike-logo-new.jpg" alt="AnyBike">
    </a>

    <nav>
      <a href="index.html">Home</a>
      <a class="active" href="available-stock.html">Available Stock</a>
      <a href="sell.html">Sell Your Motorcycle</a>
      <a href="request.html">Request a Motorcycle</a>
      <a href="export.html">Export Services</a>
      <a href="contact.html">Contact</a>
    </nav>
  </div>
</header>

<section class="hero">
  <h1>Available <span>Stock</span></h1>
  <p>Motorcycles available through AnyBike. Worldwide export enquiries welcome.</p>
</section>

<main class="wrap">

  <section class="tools">
    <div class="toolbar">
      <input id="search" placeholder="Search make, model or variant">

      <select id="make">
        <option value="">All Makes</option>
      </select>

      <select id="model">
        <option value="">All Models</option>
      </select>

      <select id="year">
        <option value="">All Years</option>
      </select>

      <select id="priceRange">
        <option value="">All Prices</option>
        <option value="0-3000">Up to £3,000</option>
        <option value="3000-6000">£3,000 - £6,000</option>
        <option value="6000-10000">£6,000 - £10,000</option>
        <option value="10000-999999">£10,000+</option>
      </select>

      <select id="currency">
        <option value="GBP">GBP £</option>
        <option value="EUR">EUR €</option>
        <option value="USD">USD $</option>
        <option value="AUD">AUD A$</option>
        <option value="NZD">NZD NZ$</option>
        <option value="CAD">CAD C$</option>
        <option value="AED">AED د.إ</option>
      </select>

      <select id="language">
        <option value="en">English</option>
        <option value="fr">Français</option>
        <option value="de">Deutsch</option>
        <option value="es">Español</option>
        <option value="ar">العربية</option>
      </select>
    </div>
  </section>

  <div class="count-row">
    <div class="count" id="count">Loading available stock...</div>
    <div class="small">Prices shown excluding shipping, duties and local taxes.</div>
  </div>

  <section class="grid" id="grid"></section>

  <button id="loadMoreBtn" class="load-more" onclick="loadMore()">Load More</button>

</main>

<footer class="footer">
  <strong>ANYBIKE.CO.UK</strong>
  <span>UK Motorcycle Export Specialists — Worldwide sourcing and export services.</span>
</footer>

<script>
const SUPABASE_URL = "https://tuehtnezhdnkqbbhttgp.supabase.co";
const SUPABASE_ANON_KEY = "sb_publishable_mrkBKDxEPVmdj2n7gPWsbg_l4CShtcK";
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

const logoFile = "anybike-logo-new.jpg";

const rates = {
  GBP:{symbol:"£",rate:1},
  EUR:{symbol:"€",rate:1.18},
  USD:{symbol:"$",rate:1.34},
  AUD:{symbol:"A$",rate:2.05},
  NZD:{symbol:"NZ$",rate:2.23},
  CAD:{symbol:"C$",rate:1.84},
  AED:{symbol:"د.إ",rate:4.92}
};

const words = {
  en:{
    request:"Request More Information",
    buy:"I Would Like To Buy This Bike",
    watch:"♡ Add To Watchlist",
    watched:"✓ Added To Watchlist",
    register:"Register Free",
    view:"To View Images",
    available:"Available"
  },
  fr:{
    request:"Demander Plus D’informations",
    buy:"Je Souhaite Acheter Cette Moto",
    watch:"♡ Ajouter À La Liste",
    watched:"✓ Ajouté À La Liste",
    register:"Inscription Gratuite",
    view:"Pour Voir Les Images",
    available:"Disponible"
  },
  de:{
    request:"Weitere Informationen Anfordern",
    buy:"Ich Möchte Dieses Motorrad Kaufen",
    watch:"♡ Zur Merkliste Hinzufügen",
    watched:"✓ Zur Merkliste Hinzugefügt",
    register:"Kostenlos Registrieren",
    view:"Um Bilder Zu Sehen",
    available:"Verfügbar"
  },
  es:{
    request:"Solicitar Más Información",
    buy:"Quiero Comprar Esta Moto",
    watch:"♡ Añadir A Favoritos",
    watched:"✓ Añadido A Favoritos",
    register:"Regístrate Gratis",
    view:"Para Ver Imágenes",
    available:"Disponible"
  },
  ar:{
    request:"طلب المزيد من المعلومات",
    buy:"أرغب في شراء هذه الدراجة",
    watch:"♡ أضف إلى قائمة المتابعة",
    watched:"✓ تمت الإضافة",
    register:"سجل مجاناً",
    view:"لعرض الصور",
    available:"متاح"
  }
};

let bikes = [];
let filteredBikes = [];
let shownCount = 0;
const PAGE_SIZE = 24;
const INITIAL_LOAD = 1000;

function currentLang(){
  return document.getElementById("language").value;
}

function text(key){
  return words[currentLang()][key] || words.en[key];
}

function currentCurrency(){
  return document.getElementById("currency").value;
}

function formatPrice(gbp){
  const n = Number(gbp || 0);
  if(!n) return "Price on request";

  const c = rates[currentCurrency()];
  const converted = Math.round(n * c.rate);
  return c.symbol + converted.toLocaleString("en-GB");
}

function formatMiles(n){
  if(!n) return "Mileage TBC";
  return Number(n).toLocaleString("en-GB") + " miles";
}

function safeText(v){
  if(v === undefined || v === null) return "";
  return String(v);
}

async function loadBikes(){
  document.getElementById("count").textContent = "Loading available stock...";

  const { data, error } = await sb
    .from("available_stock")
    .select("id,make,model,variant,year,mileage,engine_cc,price_gbp,colour,status,image_url,created_at")
    .not("make","is",null)
    .not("model","is",null)
    .order("created_at",{ascending:false})
    .limit(INITIAL_LOAD);

  if(error){
    console.error(error);
    document.getElementById("count").textContent = "Stock could not be loaded.";
    return;
  }

  bikes = (data || []).map(b => ({
    id:b.id,
    make:safeText(b.make),
    model:safeText(b.model),
    variant:safeText(b.variant),
    year:b.year || "",
    mileage:b.mileage || 0,
    cc:b.engine_cc || "",
    price:Number(b.price_gbp || 0),
    colour:safeText(b.colour),
    status:safeText(b.status) || "Available",
    image_url:safeText(b.image_url)
  }));

  populateFilters();
  applyFilters();
}

function populateFilters(){
  const makes = [...new Set(bikes.map(b => b.make).filter(Boolean))].sort();

  document.getElementById("make").innerHTML =
    '<option value="">All Makes</option>' +
    makes.map(x => `<option>${x}</option>`).join("");

  const years = [...new Set(bikes.map(b => b.year).filter(Boolean))].sort((a,b)=>b-a);

  document.getElementById("year").innerHTML =
    '<option value="">All Years</option>' +
    years.map(x => `<option>${x}</option>`).join("");

  updateModels();
}

function updateModels(){
  const selectedMake = document.getElementById("make").value;

  const models = [...new Set(
    bikes
      .filter(b => !selectedMake || b.make === selectedMake)
      .map(b => b.model)
      .filter(Boolean)
  )].sort();

  document.getElementById("model").innerHTML =
    '<option value="">All Models</option>' +
    models.map(x => `<option>${x}</option>`).join("");
}

function applyFilters(){
  const q = document.getElementById("search").value.toLowerCase();
  const make = document.getElementById("make").value;
  const model = document.getElementById("model").value;
  const year = document.getElementById("year").value;
  const priceRange = document.getElementById("priceRange").value;

  filteredBikes = bikes.filter(b => {
    const haystack = `${b.make} ${b.model} ${b.variant} ${b.year} ${b.colour}`.toLowerCase();

    if(q && !haystack.includes(q)) return false;
    if(make && b.make !== make) return false;
    if(model && b.model !== model) return false;
    if(year && String(b.year) !== String(year)) return false;

    if(priceRange){
      const [min,max] = priceRange.split("-").map(Number);
      if(!b.price || b.price < min || b.price > max) return false;
    }

    return true;
  });

  shownCount = 0;
  document.getElementById("grid").innerHTML = "";
  renderMore();
}

function bikeImage(b){
  if(b.image_url){
    return `<img class="real-image" src="${b.image_url}" alt="${b.make} ${b.model}" onerror="this.outerHTML=placeholderHTML()">`;
  }

  return placeholderHTML();
}

function placeholderHTML(){
  return `
    <div class="placeholder">
      <img class="bg-logo" src="${logoFile}" alt="">
      <div class="placeholder-text">
        ${text("register")}
        <small>${text("view")}</small>
      </div>
    </div>
  `;
}

function cardHTML(b){
  const watched = isWatched(b.id);
  const variant = b.variant || "&nbsp;";
  const yearText = b.year || "Year TBC";
  const ccText = b.cc ? `${b.cc}cc` : "CC TBC";

  return `
    <article class="card">
      ${bikeImage(b)}

      <div class="card-body">
        <span class="badge">${text("available")}</span>

        <h2>${b.make} ${b.model}</h2>

        <div class="variant">${variant}</div>

        <div class="meta">
          <div>${yearText} | ${formatMiles(b.mileage)} | ${ccText}</div>
          ${b.colour ? `<div>${b.colour}</div>` : ""}
        </div>

        <div class="price">${formatPrice(b.price)}</div>
        <div class="price-note">Base motorcycle price. Export costs quoted separately.</div>

        <div class="actions">
          <button class="primary" onclick="enquire('${b.id}','info')">${text("request")}</button>
          <button class="dark" onclick="enquire('${b.id}','buy')">${text("buy")}</button>
          <button class="watch ${watched ? "active" : ""}" onclick="toggleWatch('${b.id}', this)">
            ${watched ? text("watched") : text("watch")}
          </button>
        </div>
      </div>
    </article>
  `;
}

function renderMore(){
  const next = filteredBikes.slice(shownCount, shownCount + PAGE_SIZE);

  document.getElementById("grid").insertAdjacentHTML(
    "beforeend",
    next.map(cardHTML).join("")
  );

  shownCount += next.length;

  document.getElementById("count").textContent =
    `${filteredBikes.length.toLocaleString("en-GB")} motorcycles currently available`;

  document.getElementById("loadMoreBtn").style.display =
    shownCount >= filteredBikes.length ? "none" : "block";
}

function loadMore(){
  renderMore();
}

function findBike(id){
  return bikes.find(b => String(b.id) === String(id));
}

function enquire(id,type){
  const b = findBike(id);
  if(!b) return;

  const subject = encodeURIComponent(
    type === "buy"
      ? `I would like to buy this bike: ${b.make} ${b.model}`
      : `Request more information: ${b.make} ${b.model}`
  );

  const body = encodeURIComponent(
`Hello AnyBike,

I am interested in:

${b.make} ${b.model}
${b.variant || ""}
${b.year}
${formatPrice(b.price)}

Destination country:
Name:
Phone:

Thanks`
  );

  window.location.href = `mailto:sales@anybike.co.uk?subject=${subject}&body=${body}`;
}

function getWatchlist(){
  return JSON.parse(localStorage.getItem("anybike_watchlist") || "[]");
}

function saveWatchlist(list){
  localStorage.setItem("anybike_watchlist", JSON.stringify(list));
}

function isWatched(id){
  return getWatchlist().map(String).includes(String(id));
}

function toggleWatch(id, button){
  let list = getWatchlist().map(String);

  if(!list.includes(String(id))){
    list.push(String(id));

    const email = localStorage.getItem("anybike_email") ||
      prompt("Enter your email to save this bike to your future AnyBike dashboard:");

    if(email){
      localStorage.setItem("anybike_email", email);
    }
  }

  saveWatchlist(list);
  button.textContent = text("watched");
  button.classList.add("active");
}

["search","model","year","priceRange"].forEach(id => {
  document.getElementById(id).addEventListener("input", applyFilters);
  document.getElementById(id).addEventListener("change", applyFilters);
});

["currency","language"].forEach(id => {
  document.getElementById(id).addEventListener("change", () => {
    document.getElementById("grid").innerHTML = "";
    shownCount = 0;
    renderMore();
  });
});

document.getElementById("make").addEventListener("change", () => {
  updateModels();
  applyFilters();
});

loadBikes();
</script>

</body>
</html>
