# ========================================
# ANYBIKE - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ========================================

# Backend
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_NAME=anybike_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@anybike.co.uk
EMAIL_PASSWORD=your_email_password_here
ADMIN_EMAIL=admin@anybike.co.uk

# API Configuration
API_ENDPOINT=https://api.anybike.co.uk

# Frontend
ALLOWED_ORIGINS=http://localhost:3000,https://anybike.co.uk

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=anybike-photos
AWS_S3_REGION=eu-west-1

# Stripe (optional - for payments)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Logging
LOG_LEVEL=info
